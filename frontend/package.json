{
  "name": "fingather",
  "version": "1.16.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration ssl --open",
    "start:e2e": "ng serve --configuration e2e",
    "serve:e2e:static": "ng build --configuration e2e && node scripts/serve-e2e.cjs",
    "build": "ng build",
    "build-prod": "ng build --configuration production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "ng lint --max-warnings=0 && stylelint --max-warnings=0 src/**/*.scss",
    "lint-fix": "ng lint --fix && stylelint src/**/*.scss --fix",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "analyze": "webpack-bundle-analyzer dist/fingather/stats.json"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.4",
    "@angular/router": "^22.0.4",
    "@marekskopal/ng-scroll-shadow": "^5.0.0",
    "@ng-bootstrap/ng-bootstrap": "^21.0.0",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "@popperjs/core": "^2.11.8",
    "apexcharts": "^5.15.2",
    "bootstrap": "^5.3.8",
    "ng-apexcharts": "^2.4.0",
    "ngx-file-drop": "^16.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.1",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@babel/runtime": "^8.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.5.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^17.14.0",
    "stylelint-config-sass-guidelines": "^13.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "webpack-bundle-analyzer": "^5.3.0",
    "zone.js": "^0.16.2"
  }
}
