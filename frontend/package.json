{
  "name": "fingather",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration ssl --open",
    "start:e2e": "ng serve --configuration e2e",
    "build": "ng build",
    "build-prod": "ng build --configuration production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "ng lint && stylelint src/**/*.scss",
    "lint-fix": "ng lint --fix && stylelint src/**/*.scss --fix",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "analyze": "webpack-bundle-analyzer dist/fingather/stats.json"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.10",
    "@angular/cdk": "^21.2.8",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/material": "^21.2.8",
    "@angular/platform-browser": "^21.2.10",
    "@angular/platform-browser-dynamic": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@marekskopal/ng-scroll-shadow": "^4.0.0",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@popperjs/core": "^2.11.8",
    "apexcharts": "^5.10.6",
    "bootstrap": "^5.3.8",
    "ng-apexcharts": "^2.4.0",
    "ngx-file-drop": "^16.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.10",
    "@angular-devkit/build-angular": "^21.2.8",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.10",
    "@babel/runtime": "^7.29.2",
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^17.9.0",
    "stylelint-config-sass-guidelines": "^13.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "webpack-bundle-analyzer": "^5.3.0",
    "zone.js": "^0.16.1"
  }
}
