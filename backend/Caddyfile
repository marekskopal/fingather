:80 {
	header Access-Control-Allow-Origin  "{$BACKEND_CORS_ALLOWED_ORIGIN:*}"
	header Access-Control-Allow-Headers "{$BACKEND_CORS_ALLOWED_HEADERS:*}"
	header Access-Control-Allow-Methods "{$BACKEND_CORS_ALLOWED_METHODS:GET,POST,PUT,DELETE,OPTIONS}"
	header Access-Control-Allow-Credentials "{$BACKEND_CORS_ALLOWED_CREDENTIALS:false}"
	header Access-Control-Expose-Headers "Content-Disposition"

	@options method OPTIONS
	respond @options 204

	encode zstd gzip

	php {
		root /app/src
		worker {

			file frankenphp-worker.php
        	num {$BACKEND_FRANKENPHP_WORKERS:10}
			match *
		}
	}
}
